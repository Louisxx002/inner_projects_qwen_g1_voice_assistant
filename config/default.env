# Qwen ROS Node + Edge TTS default configuration.
# Source this file before running scripts if you want shell-level overrides.

CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${CONFIG_DIR}/.." && pwd)"

QWEN_AUDIO_TOPIC="${QWEN_AUDIO_TOPIC:-/audio_msg}"
QWEN_PYTHON="${QWEN_PYTHON:-${HOME}/miniconda3/envs/qwen/bin/python}"
QWEN_SERVER_URL="${QWEN_SERVER_URL:-http://127.0.0.1:8000/infer}"
QWEN_REQUEST_TIMEOUT_SEC="${QWEN_REQUEST_TIMEOUT_SEC:-15}"
QWEN_WAKE_WORDS="${QWEN_WAKE_WORDS:-西浦小g,小g,小G,小纪,小记,小机,小鸡,hey gee,hey g,XJTLU Gee,せいほくジーくん,ジーくん}"
QWEN_ALWAYS_LISTEN="${QWEN_ALWAYS_LISTEN:-0}"

QWEN_MODEL_PATH="${QWEN_MODEL_PATH:-${PROJECT_ROOT}/models/Qwen3.5-0.8B/model}"
if [[ ! -d "${QWEN_MODEL_PATH}" && -d "${HOME}/Qwen3.5-0.8B/model" ]]; then
  QWEN_MODEL_PATH="${HOME}/Qwen3.5-0.8B/model"
fi

QWEN_SERVER_HOST="${QWEN_SERVER_HOST:-0.0.0.0}"
QWEN_SERVER_PORT="${QWEN_SERVER_PORT:-8000}"
QWEN_MAX_NEW_TOKENS="${QWEN_MAX_NEW_TOKENS:-50}"
QWEN_TEMPERATURE="${QWEN_TEMPERATURE:-0.7}"
QWEN_RUNTIME_DIR="${QWEN_RUNTIME_DIR:-${PROJECT_ROOT}/runtime}"

UNITREE_DOMAIN_ID="${UNITREE_DOMAIN_ID:-0}"
UNITREE_NETWORK_INTERFACE="${UNITREE_NETWORK_INTERFACE:-enp8s0}"
UNITREE_AUDIO_VOLUME="${UNITREE_AUDIO_VOLUME:-85}"

QWEN_ACTION_ENABLE="${QWEN_ACTION_ENABLE:-0}"
QWEN_ACTION_EXECUTE="${QWEN_ACTION_EXECUTE:-0}"
QWEN_ACTION_BACKEND="${QWEN_ACTION_BACKEND:-qwen}"
QWEN_ACTION_THRESHOLD="${QWEN_ACTION_THRESHOLD:-0.8}"
QWEN_ACTION_AUTO_RELEASE="${QWEN_ACTION_AUTO_RELEASE:-0}"
QWEN_ACTION_PYTHON="${QWEN_ACTION_PYTHON:-${PROJECT_ROOT}/external/unitree_g1_action_classifier_package/.venv/bin/python}"
QWEN_ACTION_SCRIPT="${QWEN_ACTION_SCRIPT:-${PROJECT_ROOT}/external/unitree_g1_action_classifier_package/arm_action_classifier/arm_action_classifier.py}"
QWEN_ACTION_RUNNER="${QWEN_ACTION_RUNNER:-${PROJECT_ROOT}/external/unitree_g1_action_classifier_package/unitree_sdk2/build/bin/g1_arm_action_example}"
